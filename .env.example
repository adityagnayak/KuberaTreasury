# =====================================
# KuberaTreasury Environment Variables
# =====================================
# This file is template-only and contains no secrets.
# Generation guidance:
# - Use `openssl rand -hex 32` (or equivalent) for 256-bit random secrets.
# - Use bcrypt cost >= 12.
# - Never commit real values.

# ---------- Core ----------
APP_NAME=KuberaTreasury
APP_ENV=development # development|staging|production
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
API_VERSION=v1

# ---------- Security / Auth ----------
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=30
JWT_SECRET_KEY=replace_with_64_hex_chars # USER ACTION REQUIRED: generate with `openssl rand -hex 32`
BCRYPT_ROUNDS=12
SESSION_IDLE_TIMEOUT_MINUTES=15
MFA_TOTP_ISSUER=KuberaTreasury
MFA_TOTP_ENCRYPTION_KEY=replace_with_64_hex_chars # USER ACTION REQUIRED: AES-256 key (32 random bytes), e.g. `openssl rand -hex 32`
IP_ALLOWLIST_ENFORCED=true

# ---------- Database ----------
DATABASE_URL=postgresql+psycopg://user:pass@host:5432/kuberatreasury
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=20
DATABASE_CONNECT_TIMEOUT_SECONDS=10
REPORTING_DATABASE_URL=postgresql+psycopg://user:pass@read-replica:5432/kuberatreasury_reporting

# ---------- Cache ----------
REDIS_URL=redis://:password@host:6379/0
REDIS_TTL_SECONDS=900

# ---------- Alembic ----------
ALEMBIC_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/kuberatreasury

# ---------- HMRC / Tax ----------
HMRC_API_BASE_URL=https://api.service.hmrc.gov.uk
HMRC_API_VERSION=v1.0
HMRC_CLIENT_ID=replace_with_hmrc_client_id
HMRC_CLIENT_SECRET=replace_with_hmrc_client_secret
HMRC_OAUTH_REDIRECT_URI=https://your-domain.example.com/callback/hmrc
HMRC_SANDBOX_MODE=true
HMRC_TOKEN_ENCRYPTION_KEY=replace_with_64_hex_chars # USER ACTION REQUIRED: AES-256 key for HMRC OAuth tokens (32 random bytes)
HMRC_VAT_MTD_ENABLED=true
HMRC_CT_MTD_PREPARED=true # readiness flag for Apr-2026

# ---------- AI ----------
ANTHROPIC_API_KEY=replace_with_anthropic_api_key # USER ACTION REQUIRED for production/Claude
GEMINI_API_KEY=replace_with_gemini_api_key # USER ACTION REQUIRED when AI_PROVIDER=gemini
AI_MODEL_NAME=claude-sonnet-4-6
GEMINI_MODEL_NAME=gemini-2.0-flash
AI_PROVIDER=ollama # USER ACTION REQUIRED: set `claude` or `gemini` in production
AI_PROVIDER_GEMINI_DEPRECATED=false # USER ACTION REQUIRED when sunsetting Gemini: set true
AI_PII_BLOCKING_ENFORCED=true
AI_AUDIT_LOGGING_ENFORCED=true

# ---------- Storage / Exports ----------
EXPORT_STORAGE_PROVIDER=s3 # s3|gcs|azure
EXPORT_STORAGE_BUCKET=kuberatreasury-exports
EXPORT_STORAGE_REGION=eu-west-2
AUDIT_PDF_SIGNING_KEY_ID=replace_with_key_id
AUDIT_PDF_SIGNING_PRIVATE_KEY=replace_with_private_key_material # USER ACTION REQUIRED: load from secret manager / KMS, never commit
# UAT-only fallback: you may use temporary local signing credentials with non-production data.
# Production: must use managed KMS/HSM-backed signing keys and rotated secrets.

# ---------- Payments ----------
PAYMENT_INITIATION_MODE=manual_pain001_only
PAIN001_OUTPUT_DIRECTORY=./exports/pain001
ISO20022_SCHEMA_VERSION=pain.001.001.09
SANCTIONS_MATCH_THRESHOLD=85
SANCTIONS_PROXIMITY_THRESHOLD=60
AML_STRUCTURING_NEAR_THRESHOLD_GBP=250

# ---------- Observability ----------
LOG_LEVEL=INFO
LOG_JSON=true
AUDIT_LOG_IMMUTABLE=true
TRACE_ENABLED=true

# ---------- CI / Security ----------
CI_PIP_AUDIT_ENFORCED=true
CI_NPM_AUDIT_ENFORCED=true
SECRETS_ROTATION_DAYS=90
SECURITY_CONTACT_EMAIL=security@kubera.example
